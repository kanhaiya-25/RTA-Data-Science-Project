library(dplyr)
library(tidyr)
data <- read.csv("Educational_Statistics_Wide.csv")
filtered_data <- data %>%
mutate(
Literacy_Gap = Literacy_Male - Literacy_Female,
Enrollment_Change = Enrollment_Primary - Enrollment_Secondary
) %>%
filter(Literacy_Gap > 10, Dropout_Rate < 4)
filtered_data
#2
state_summary <- data %>%
group_by(Country_State) %>%
summarise(
Avg_Male_Literacy = mean(Literacy_Male),
Avg_Female_Literacy = mean(Literacy_Female),
Avg_Dropout = mean(Dropout_Rate),
Avg_Literacy_Gap = mean(Literacy_Male - Literacy_Female)
) %>%
arrange(desc(Avg_Literacy_Gap))
top_two_states <- state_summary %>% slice(1:2)
top_two_states
#3
long_literacy <- data %>%
pivot_longer(
cols = c(Literacy_Male, Literacy_Female),
names_to = "Indicator",
values_to = "Value"
)
long_literacy
#4
smallest_gap <- data %>%
group_by(Country_State) %>%
summarise(Avg_Gap = mean(Literacy_Male - Literacy_Female)) %>%
arrange(Avg_Gap) %>%
slice(1)
smallest_gap
#5
gender_index <- data %>%
group_by(Country_State) %>%
summarise(
Literacy_Male = mean(Literacy_Male),
Literacy_Female = mean(Literacy_Female)
) %>%
mutate(Gender_Equality_Index = Literacy_Female / Literacy_Male) %>%
arrange(desc(Gender_Equality_Index))
gender_index
