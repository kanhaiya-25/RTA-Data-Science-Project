# Step 0: Read the CSV file
attendance <- read.csv("attendance.csv")
# 1) Students with attendance below 75%
below_75 <- attendance[attendance$AttendancePercentage < 75, ]
print("Students with attendance below 75%:")
print(below_75)
# 2) Add Eligibility column
attendance$Eligibility <- ifelse(
attendance$AttendancePercentage >= 75,"Eligible","Not Eligible")
print("Updated data with Eligibility column:")
print(attendance)
# 3) Export updated data to a new CSV with row names
write.csv(attendance, "export_attendance.csv", row.names = TRUE)
print("Updated data exported to 'export_attendance.csv'.")
# 4) Average AttendancePercentage of Eligible students
avg_attendance <mean(attendance$AttendancePercentage[attendance$Eligibility =="Eligible"])
# Step 0: Read the CSV file
attendance <- read.csv("attendance.csv")
# 1) Students with attendance below 75%
