arrange(desc(Avg_BMI_like)) %>%
slice(1:3)
top_species
#3
species_gender_stats <- clean_sw %>%
group_by(species, gender) %>%
summarise(
Avg_Height = mean(height),
Avg_Mass = mean(mass),
.groups = "drop"
)
species_gender_stats
#4
homeworld_lookup <- data.frame(
homeworld = c("Tatooine", "Naboo", "Alderaan", "Coruscant"),
region = c("Outer Rim", "Mid Rim", "Core Worlds", "Core Worlds")
)
inner_join(clean_sw, homeworld_lookup, by = "homeworld")
left_join(clean_sw, homeworld_lookup, by = "homeworld")
right_join(clean_sw, homeworld_lookup, by = "homeworld")
full_join(clean_sw, homeworld_lookup, by = "homeworld")
#5
long_sw <- clean_sw %>%
pivot_longer(
cols = c(height, mass, BMI_like),
names_to = "Attribute",
values_to = "Value"
)
summary_sw <- long_sw %>%
group_by(species, Attribute) %>%
summarise(Mean_Value = mean(Value), .groups = "drop")
wide_summary <- summary_sw %>%
pivot_wider(names_from = Attribute, values_from = Mean_Value)
wide_summary
ggplot(wide_summary, aes(x = species, y = BMI_like)) +
geom_col() +
coord_flip() +
labs(title = "BMI-like Comparison Across Species",
x = "Species",
y = "Average BMI-like")
