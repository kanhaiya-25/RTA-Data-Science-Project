# 5) Count number of Eligible and Not Eligible students (Option 1)
num_eligible <- sum(attendance$Eligibility == "Eligible")
num_not_eligible <- sum(attendance$Eligibility == "Not Eligible")
print(c(Eligible = num_eligible, Not_Eligible = num_not_eligible))
